{
  "name": "obsidian-note-player",
  "version": "0.6.0",
  "description": "Play note-backed playlists inside Obsidian — YouTube, cached audio, and local files.",
  "main": "main.js",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "sync:styles": "node scripts/sync-styles.mjs",
    "dev:build": "pnpm run sync:styles && node esbuild.config.mjs",
    "build": "pnpm run sync:styles && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "ci": "pnpm run build && pnpm run lint && pnpm run test",
    "version": "node scripts/version.mjs",
    "postversion": "git push && git push --tags",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "keywords": [
    "obsidian",
    "youtube",
    "playlist",
    "music"
  ],
  "author": "Beomsu Koh",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.47.0",
    "globals": "^15.15.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
